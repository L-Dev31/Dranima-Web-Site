    "entries": [
        {
            "id": "base",
            "name": "Base",
            "category": "how-to-play",
            "icon": "images/character1.png",
            "preview": "Your Base is your home in Dranima. It's where you manage resources, train Dranimae, and prepare for your adventures across the land.",
            "sections": [
                {
                    "title": "Base Overview",
                    "content": "Your Base serves as your personal headquarters in the world of Dranima. It's a safe space where you can organize your team, craft items, and plan your next moves. As you progress through the game, you can upgrade and expand your Base with new buildings and features."
                },
                {
                    "title": "Building and Upgrading",
                    "content": "You can construct various buildings within your Base to unlock new features:<br>- <strong>Training Grounds</strong>: Increase your Dranimae's experience gain<br>- <strong>Crafting Workshop</strong>: Create healing items and useful tools<br>- <strong>Sleep Quarters</strong>: Restore full health to your team<br>- <strong>Storage Facility</strong>: Increase your inventory capacity<br>Each building can be upgraded multiple times for better results."
                },
                {
                    "title": "Daily Activities",
                    "content": "Visit your Base regularly to take advantage of its features. You can feed your Dranimae, repair equipment, and organize your bag here. Many players like to visit their Base between adventures to ensure their team is in peak condition before heading out into the world."
                }
            ]
        },
